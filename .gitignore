# ============== Unity ==============
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should always be kept
!/[Aa]ssets/**/*.meta

# Auto-generated solution / project files
*.csproj
*.unityproj
*.sln
*.slnx
*.slnx-keepalive
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.slnx.suo

# Unity Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.ipa
*.exe
*.x86_64
*.x86
*.app/

# Addressables build cache (built content goes to ServerData/, ignore)
[Aa]ssets/AddressableAssetsData/*/*.bin*
[Ss]erver[Dd]ata/

# Crashlytics generated
crashlytics-build.properties

# Firebase service files (don't commit secrets — use per-env)
google-services.json
GoogleService-Info.plist

# Per-game encryption seeds — committed `.example` only
[Aa]ssets/[Rr]esources/ZeroSecrets.asset
[Aa]ssets/[Rr]esources/ZeroSecrets.asset.meta

# Per-user Claude Code settings (project-level shared settings.json may be committed)
.claude/settings.local.json

# ============== OS ==============
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============== IDE ==============
.idea/
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
*.swp

# Re-include UPM package "hidden" folders (Unity convention: ~ suffix = Unity ignores; git must NOT).
# Some users have *~ in their global gitignore for emacs backups — this overrides that for these specific paths.
!Packages/**/Documentation~/
!Packages/**/Documentation~/**
!Packages/**/Samples~/
!Packages/**/Samples~/**

# Override global "log" pattern for Zero.Services.Log asmdef folder.
# Some users have lowercase "log" in their global gitignore for log files —
# on case-insensitive filesystems (macOS default) it accidentally matches the Log/ folder
# that contains LogService + asmdef. Without this negation, `git mv` silently drops the
# folder contents during refactors, breaking CI compile on case-sensitive Linux.
!Packages/**/Services/Log/
!Packages/**/Services/Log/**
