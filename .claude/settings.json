{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(rg:*)"
    ],
    "ask": [
      "Edit(./Packages/manifest.json)",
      "Edit(./Packages/com.tnbao91.nobody.zero/package.json)",
      "Edit(./CHANGELOG.md)"
    ],
    "deny": [
      "Read(./Assets/Resources/ZeroSecrets.asset)",
      "Read(./**/*.keystore)",
      "Read(./**/keystore.properties)",
      "Read(./**/*.p12)",
      "Read(./**/*.mobileprovision)",
      "Read(./.env)",
      "Read(./**/.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-footguns.sh",
            "statusMessage": "Checking Unity footguns…"
          }
        ]
      }
    ]
  }
}
